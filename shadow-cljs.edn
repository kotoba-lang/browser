{:deps  {:aliases [:cljs]}
 :nrepl {:port 9633}
 :builds
 {:node-test
  {:target     :node-test
   :output-to  "target/node-tests.js"
   :ns-regexp  "-smoke-test$"
   :autorun    true}

  :browser-demo
  {:target     :browser
   :output-dir "public/js"
   :asset-path "/js"
   :modules    {:browser-demo {:init-fn browser.demo/init!}}
   :release    {:compiler-options {:optimizations :advanced}}
   :devtools   {:watch-dir "public"
                :http-root "public"
                :http-port 8702}}

  :visual-smoke
  {:target     :browser
   :output-dir "public/js"
   :asset-path "/js"
   :modules    {:visual-smoke {:init-fn browser.smoke/init!}}
   :release    {:compiler-options {:optimizations :advanced}}
   :devtools   {:watch-dir "public"
                :http-root "public"
                :http-port 8702}}

  :webgpu-smoke
  {:target     :browser
   :output-dir "public/js"
   :asset-path "/js"
   :modules    {:webgpu-smoke {:init-fn browser.smoke-webgpu/init!}}
   :release    {:compiler-options {:optimizations :advanced}}
   :devtools   {:watch-dir "public"
                :http-root "public"
                :http-port 8702}}}}
